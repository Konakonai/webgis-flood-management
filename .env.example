# Copy this file to .env before starting the stack. Values below are for a
# local classroom/demo environment only; replace all secrets before exposing
# the stack outside localhost.

# Host bindings (127.0.0.1 keeps every published service local by default)
BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=8088
BACKEND_PORT=8080
POSTGRES_PORT=5432
OSRM_PORT=5000

# PostgreSQL/PostGIS
POSTGRES_DB=flood_gis
POSTGRES_USER=gis
POSTGRES_PASSWORD=floodgis_demo_change_me

# Spring Boot. Use a random value of at least 64 characters in non-demo use.
JWT_SECRET=demo-only-flood-gis-jwt-secret-change-before-any-shared-deployment-2026
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088
JAVA_OPTS=-XX:MaxRAMPercentage=70.0 -XX:+ExitOnOutOfMemoryError
UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_MAX_IMAGE_PIXELS=25000000

# OSRM. The default is the current Jiangsu Geofabrik extract (about 74 MB as
# of July 2026). The first start downloads and preprocesses it with MLD.
OSRM_DATA_URL=https://download.geofabrik.de/asia/china/jiangsu-latest.osm.pbf
OSRM_DATA_FILE=jiangsu-latest.osm.pbf
OSRM_PROFILE=car
OSRM_THREADS=2
OSRM_FORCE_REBUILD=false
